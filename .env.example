# Cloud-Sync (optional). Ohne diese Werte läuft SemBan rein lokal weiter.
# Werte findest du im Supabase-Dashboard unter: Project Settings → API.
VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

# Web-Push-Erinnerungen (optional). Öffentlicher VAPID-Key – siehe docs/REMINDERS.md.
# Ohne diesen Wert funktionieren nur lokale Benachrichtigungen (App offen/zurück),
# kein Push bei geschlossener App.
VITE_VAPID_PUBLIC_KEY=dein-vapid-public-key
